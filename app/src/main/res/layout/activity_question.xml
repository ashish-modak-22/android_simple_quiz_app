<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".supporting.QuestionActivity">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="top|center"
        android:padding="15dp">
        
        <TextView
            android:id="@+id/question_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="normal"
            android:gravity="center"
            tools:text="Which continent does the country belong to?"/>


        <ImageView
            android:layout_marginTop="18dp"
            android:id="@+id/flag_images"
            android:layout_width="wrap_content"
            android:layout_height="240dp"
            android:contentDescription="@string/flag_image"
            tools:src="@drawable/india"/>

         <androidx.appcompat.widget.LinearLayoutCompat
             android:layout_marginTop="13dp"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="horizontal"
             android:weightSum="10">
             
             <ProgressBar
                 android:id="@+id/progress_bar"
                 android:layout_width="0dp"
                 android:layout_height="wrap_content"
                 android:layout_weight="9"
                 style="?android:attr/progressBarStyleHorizontal"
                 android:max="10"
                 android:minHeight="50dp"
                 android:indeterminate="false"
                 tools:progress="7"/>     <!-- tools: is used to hide contents during runtime, it is used for preview only-->

             <TextView
                 android:id="@+id/text_view_progress"
                 android:layout_width="0dp"
                 android:layout_height="wrap_content"
                 tools:text="0/10"
                 android:textSize="16sp"
                 android:layout_weight="1"
                 android:layout_gravity="center_vertical"
                 android:layout_marginStart="6dp"/>

         </androidx.appcompat.widget.LinearLayoutCompat>
        
        <TextView
            android:id="@+id/textView_first_option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#282727"
            android:gravity="center"
            tools:text="Option 1"
            android:textSize="24sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/option_bg"
            android:minHeight="56dp"/>

        <TextView
            android:id="@+id/textView_second_option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#282727"
            android:gravity="center"
            tools:text="Option 2"
            android:textSize="24sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/option_bg"
            android:minHeight="56dp"/>


        <TextView
            android:id="@+id/textView_third_option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#282727"
            android:gravity="center"
            tools:text="Option 3"
            android:textSize="24sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/option_bg"
            android:minHeight="56dp"/>

        <TextView
            android:id="@+id/textView_fourth_option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#282727"
            android:gravity="center"
            tools:text="Option 4"
            android:textSize="24sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/option_bg"
            android:minHeight="56dp"/>

        <Button
            android:id="@+id/button_checking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_your_answer"
            android:background="#073DFF"
            android:textColor="@color/white"
            android:layout_marginTop="30dp"
            android:textStyle="normal"
            android:textSize="14sp"
            android:minHeight="56dp"/>

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.core.widget.NestedScrollView>